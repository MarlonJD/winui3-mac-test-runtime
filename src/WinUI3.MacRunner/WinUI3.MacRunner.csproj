<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\WinUI3.MacRuntime\WinUI3.MacRuntime.csproj" />
    <ProjectReference Include="..\WinUI3.MacCompat\WinUI3.MacCompat.csproj" />
    <ProjectReference Include="..\WinUI3.MacXaml\WinUI3.MacXaml.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>MarlonJD.WinUI3.MacRunner</PackageId>
    <Description>CLI runner for Wine-free WinUI3 macOS test runtime artifacts.</Description>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>winui3-mac-runner</ToolCommandName>
  </PropertyGroup>

</Project>
