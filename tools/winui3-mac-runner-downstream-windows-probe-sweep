#!/usr/bin/env bash
set -u -o pipefail

usage() {
  cat <<'USAGE'
Usage: winui3-mac-runner-downstream-windows-probe-sweep [--output <dir>] [--reference <png-or-native-reference-dir>] [--require-native-comparison] [--windows-screenshot-dir <dir>]

Runs every MeetingChallenge Windows macOS runtime probe scenario with
skia-v2 strict visual mode and writes summary.json, summary.md, and review.html.
When --reference points to a normalized native-reference-import directory, each
scenario is compared against its matching Windows reference image.
When --windows-screenshot-dir points to a structured probe capture directory
with <scenario>/windows-reference.png files, those PNGs are consumed as true
per-scenario Windows references and copied into each scenario visual artifact
directory before pixel diffing.
Use --require-native-comparison in CI/release gates to fail when any native
comparison is skipped or failed.
Use --windows-screenshot-dir to add existing Windows runner page screenshots to
review.html for side-by-side visual review. Legacy flat JPG screenshots remain
review-only and are not pixel-diff evidence.
USAGE
}

output="/private/tmp/emsi-windows-probe-sweep"
reference=""
windows_screenshot_dir=""
require_native_comparison=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --output)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for --output" >&2
        exit 2
      fi
      output="$2"
      shift 2
      ;;
    --reference)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for --reference" >&2
        exit 2
      fi
      reference="$2"
      shift 2
      ;;
    --windows-screenshot-dir)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for --windows-screenshot-dir" >&2
        exit 2
      fi
      windows_screenshot_dir="$2"
      shift 2
      ;;
    --require-native-comparison)
      require_native_comparison=true
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
runtime_root="$(cd "$script_dir/.." && pwd)"
monorepo_root="$(cd "$runtime_root/../.." && pwd)"
probe_root="$monorepo_root/apps/windows/tests/MeetingChallenge.WinUI.MacRuntimeProbe"
project="$probe_root/MeetingChallenge.WinUI.MacRuntimeProbe.csproj"
scenario_dir="$probe_root/scenarios"
runner="$runtime_root/tools/winui3-mac-runner"

scenarios=(
  "login-light.json"
  "shell-staff-light.json"
  "messages-multiline-light.json"
  "admin-dashboard-light.json"
  "admin-workbench-light.json"
  "command-search-light.json"
  "status-states-light.json"
  "settings-profile-light.json"
)

expected_scenario_groups=(
  "login"
  "read-surface"
  "messages-multiline"
  "admin-dashboard"
  "admin-workbench"
  "command-search"
  "status-states"
  "settings-profile"
)

expected_artifacts=(
  "run.json"
  "tree.json"
  "accessibility.json"
  "interactions.json"
  "strict-scenario.log"
  "visual/mac-runtime.png"
  "visual/visual-run.json"
)

scenario_group() {
  case "$1" in
    login-light.json) echo "login" ;;
    shell-staff-light.json) echo "read-surface" ;;
    messages-multiline-light.json) echo "messages-multiline" ;;
    admin-dashboard-light.json) echo "admin-dashboard" ;;
    admin-workbench-light.json) echo "admin-workbench" ;;
    command-search-light.json) echo "command-search" ;;
    status-states-light.json) echo "status-states" ;;
    settings-profile-light.json) echo "settings-profile" ;;
    *) echo "unknown" ;;
  esac
}

scenario_surface() {
  case "$1" in
    login-light.json) echo "Login route and credential form" ;;
    shell-staff-light.json) echo "Home/read surface shell" ;;
    messages-multiline-light.json) echo "Messages multiline input route" ;;
    admin-dashboard-light.json) echo "Admin dashboard summary route" ;;
    admin-workbench-light.json) echo "Admin workbench list/detail route" ;;
    command-search-light.json) echo "Command/search region" ;;
    status-states-light.json) echo "Status/loading/error states" ;;
    settings-profile-light.json) echo "Settings/profile form route" ;;
    *) echo "Unknown route" ;;
  esac
}

windows_screenshot_name() {
  case "$1" in
    login-light.json) echo "windows-page-login.jpg" ;;
    shell-staff-light.json) echo "windows-page-home.jpg" ;;
    messages-multiline-light.json) echo "windows-page-messages.jpg" ;;
    admin-dashboard-light.json) echo "windows-page-admin.jpg" ;;
    admin-workbench-light.json) echo "windows-page-admin.jpg" ;;
    settings-profile-light.json) echo "windows-page-settings.jpg" ;;
    *) echo "" ;;
  esac
}

reference_viewport() {
  local reference_image="$1"
  local metadata_path
  metadata_path="$(dirname "$reference_image")/windows-reference.json"
  if [[ ! -f "$metadata_path" ]]; then
    return 0
  fi

  local width
  local height
  width="$(awk '/"viewport":/ { in_viewport=1; next } in_viewport && /"width":/ { gsub(/[",]/, "", $2); print $2; exit }' "$metadata_path")"
  height="$(awk '/"viewport":/ { in_viewport=1; next } in_viewport && /"height":/ { gsub(/[",]/, "", $2); print $2; exit }' "$metadata_path")"
  if [[ "$width" =~ ^[0-9]+$ && "$height" =~ ^[0-9]+$ && "$width" -gt 0 && "$height" -gt 0 ]]; then
    printf '%sx%s\n' "$width" "$height"
  fi
}

mkdir -p "$output"
summary_json="$output/summary.json"
summary_md="$output/summary.md"
review_html="$output/review.html"
tmp_entries="$output/.summary-entries.jsonl"
tmp_groups="$output/.scenario-groups.jsonl"
tmp_found_groups="$output/.found-scenario-groups.txt"
windows_screenshot_output_dir="$output/windows-runner"
: > "$tmp_entries"
: > "$tmp_groups"
: > "$tmp_found_groups"

passed=0
failed=0
native_comparison_status="skipped"
native_comparison_reason="No Windows reference image was provided."
native_comparison_interpretation="This sweep proves macOS runtime rendering, diagnostics, and screenshot generation for the listed downstream Windows probe scenarios. It does not prove native Windows pixel parity until Windows reference images are supplied."
native_comparison_passed=0
native_comparison_failed=0
native_comparison_skipped=0
reference_readiness_status="not-requested"
reference_readiness_reason="No Windows reference image was requested."
missing_reference_count=0
missing_references_json=""
coverage_complete=true
missing_scenario_group_count=0
missing_scenario_groups_json=""
interaction_passed=0
interaction_failed=0
interaction_missing=0
route_anchor_warning_count=0
artifact_passed=0
artifact_failed=0
artifact_missing_total=0
font_passed=0
font_failed=0
font_missing=0
windows_screenshot_matched=0
windows_screenshot_missing=0
native_reference_requested=false
image_integrity_passed=0
image_integrity_failed=0
image_integrity_missing=0
image_integrity_warning_count=0
low_content_warning_threshold=2
image_size_warning_count=0
started_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

for scenario in "${scenarios[@]}"; do
  scenario_path="$scenario_dir/$scenario"
  scenario_name="${scenario%.json}"
  coverage_group="$(scenario_group "$scenario")"
  coverage_surface="$(scenario_surface "$scenario")"
  scenario_output="$output/$scenario_name"
  log_path="$scenario_output/strict-scenario.log"
  mkdir -p "$scenario_output"
  scenario_reference="$reference"
  scenario_reference_viewport=""
  windows_screenshot_status="not-requested"
  windows_screenshot_path=""
  windows_screenshot_source=""
  windows_screenshot_file="$(windows_screenshot_name "$scenario")"
  if [[ -n "$windows_screenshot_dir" ]]; then
    windows_screenshot_status="missing"
    workflow_windows_screenshot="$windows_screenshot_dir/$scenario_name/windows-reference.png"
    legacy_windows_screenshot=""
    if [[ -n "$windows_screenshot_file" ]]; then
      legacy_windows_screenshot="$windows_screenshot_dir/$windows_screenshot_file"
    fi
    for candidate_windows_screenshot in "$workflow_windows_screenshot" "$legacy_windows_screenshot"; do
      if [[ -n "$candidate_windows_screenshot" && -f "$candidate_windows_screenshot" ]]; then
        mkdir -p "$windows_screenshot_output_dir"
        windows_screenshot_extension="${candidate_windows_screenshot##*.}"
        windows_screenshot_path="$windows_screenshot_output_dir/$scenario_name.$windows_screenshot_extension"
        cp "$candidate_windows_screenshot" "$windows_screenshot_path"
        windows_screenshot_source="$candidate_windows_screenshot"
        windows_screenshot_status="matched"
        windows_screenshot_matched=$((windows_screenshot_matched + 1))
        if [[ -z "$reference" && "$candidate_windows_screenshot" == "$workflow_windows_screenshot" ]]; then
          scenario_reference="$windows_screenshot_dir/$scenario_name/windows-reference.png"
          native_reference_requested=true
        fi
        break
      fi
    done
    if [[ "$windows_screenshot_status" == "missing" ]]; then
      windows_screenshot_missing=$((windows_screenshot_missing + 1))
    fi
  fi

  if [[ ! -f "$scenario_path" ]]; then
    status="failed"
    failed=$((failed + 1))
    message="missing scenario file"
    printf '%s\n' "$message" > "$log_path"
  else
    if [[ -n "$scenario_reference" ]]; then
      scenario_reference_viewport="$(reference_viewport "$scenario_reference")"
      runner_args=(
        run
        --project "$project"
        --renderer skia-v2
        --scenario "$scenario_path"
        --strict-visual
        --output "$scenario_output"
      )
      if [[ -n "$scenario_reference_viewport" ]]; then
        runner_args+=(--viewport "$scenario_reference_viewport")
      fi
      runner_args+=(--reference "$scenario_reference")
      "$runner" "${runner_args[@]}" > "$log_path" 2>&1
    else
      "$runner" run \
        --project "$project" \
        --renderer skia-v2 \
        --scenario "$scenario_path" \
        --strict-visual \
        --output "$scenario_output" \
        > "$log_path" 2>&1
    fi
    exit_code=$?
    if [[ $exit_code -eq 0 ]]; then
      status="passed"
      passed=$((passed + 1))
      message="strict visual scenario passed"
    else
      status="failed"
      failed=$((failed + 1))
      message="strict visual scenario failed with exit code $exit_code"
    fi
  fi

  pixel_diff_path="$scenario_output/visual/pixel-diff.json"
  if [[ -f "$pixel_diff_path" ]]; then
    comparison_status="$(sed -n 's/.*"status": "\([^"]*\)".*/\1/p' "$pixel_diff_path" | head -1)"
    comparison_reason="$(sed -n 's/.*"reason": "\([^"]*\)".*/\1/p' "$pixel_diff_path" | head -1)"
    comparison_message="$(sed -n 's/.*"message": "\([^"]*\)".*/\1/p' "$pixel_diff_path" | head -1)"
  else
    comparison_status="$native_comparison_status"
    comparison_reason="$native_comparison_reason"
    comparison_message=""
  fi
  if [[ -z "$comparison_status" ]]; then
    comparison_status="$native_comparison_status"
  fi
  if [[ -z "$comparison_reason" ]]; then
    if [[ -n "$comparison_message" ]]; then
      comparison_reason="$comparison_message"
    elif [[ -n "$scenario_reference" && "$comparison_status" == "failed" ]]; then
      comparison_reason="Native comparison exceeded conservative pixel thresholds."
    else
      comparison_reason="$native_comparison_reason"
    fi
  fi
  case "$comparison_status" in
    passed)
      native_comparison_passed=$((native_comparison_passed + 1))
      ;;
    failed)
      native_comparison_failed=$((native_comparison_failed + 1))
      ;;
    *)
      native_comparison_skipped=$((native_comparison_skipped + 1))
      ;;
  esac

  reference_problem=""
  if [[ -n "$scenario_reference" && ! -f "$pixel_diff_path" ]]; then
    if [[ ! -e "$scenario_reference" ]]; then
      reference_problem="Reference image or directory was not found: $scenario_reference"
    elif grep -q "No native WinUI reference image" "$log_path"; then
      reference_problem="$(grep -m 1 "No native WinUI reference image" "$log_path")"
    elif grep -q "Reference image or directory was not found" "$log_path"; then
      reference_problem="$(grep -m 1 "Reference image or directory was not found" "$log_path")"
    elif grep -q "Imported native reference image from manifest was not found" "$log_path"; then
      reference_problem="$(grep -m 1 "Imported native reference image from manifest was not found" "$log_path")"
    fi
  fi
  if [[ -n "$reference_problem" ]]; then
    missing_reference_count=$((missing_reference_count + 1))
    escaped_problem="${reference_problem//\\/\\\\}"
    escaped_problem="${escaped_problem//\"/\\\"}"
    escaped_log="${log_path//\\/\\\\}"
    escaped_log="${escaped_log//\"/\\\"}"
    if [[ -n "$missing_references_json" ]]; then
      missing_references_json="$missing_references_json,"
    fi
    missing_references_json="$missing_references_json{\"scenario\":\"$scenario\",\"reason\":\"$escaped_problem\",\"log\":\"$escaped_log\"}"
  fi

  visual_run_path="$scenario_output/visual/visual-run.json"
  image_integrity_status="missing"
  image_integrity_nonblank=false
  image_integrity_distinct=0
  image_integrity_non_background=0
  expected_viewport_width=0
  expected_viewport_height=0
  actual_image_width=0
  actual_image_height=0
  if [[ -f "$visual_run_path" ]]; then
    expected_viewport_width="$(awk '/"viewport":/ { in_viewport=1; next } in_viewport && /"width":/ { gsub(/[",]/, "", $2); print $2; exit }' "$visual_run_path")"
    expected_viewport_height="$(awk '/"viewport":/ { in_viewport=1; next } in_viewport && /"height":/ { gsub(/[",]/, "", $2); print $2; exit }' "$visual_run_path")"
    image_integrity_status="$(awk '/"runtimeImageIntegrity":/ { in_integrity=1; next } in_integrity && /"status":/ { gsub(/[",]/, "", $2); print $2; exit }' "$visual_run_path")"
    image_integrity_nonblank="$(awk '/"runtimeImageIntegrity":/ { in_integrity=1; next } in_integrity && /"isNonBlank":/ { gsub(/[",]/, "", $2); print $2; exit }' "$visual_run_path")"
    actual_image_width="$(awk '/"runtimeImageIntegrity":/ { in_integrity=1; next } in_integrity && /"width":/ { gsub(/[",]/, "", $2); print $2; exit }' "$visual_run_path")"
    actual_image_height="$(awk '/"runtimeImageIntegrity":/ { in_integrity=1; next } in_integrity && /"height":/ { gsub(/[",]/, "", $2); print $2; exit }' "$visual_run_path")"
    image_integrity_distinct="$(awk '/"runtimeImageIntegrity":/ { in_integrity=1; next } in_integrity && /"distinctColorCount":/ { gsub(/[",]/, "", $2); print $2; exit }' "$visual_run_path")"
    image_integrity_non_background="$(awk '/"runtimeImageIntegrity":/ { in_integrity=1; next } in_integrity && /"nonBackgroundPixelPercentage":/ { gsub(/[",]/, "", $2); print $2; exit }' "$visual_run_path")"
  fi
  if [[ -z "$expected_viewport_width" ]]; then
    expected_viewport_width=0
  fi
  if [[ -z "$expected_viewport_height" ]]; then
    expected_viewport_height=0
  fi
  if [[ -z "$actual_image_width" ]]; then
    actual_image_width=0
  fi
  if [[ -z "$actual_image_height" ]]; then
    actual_image_height=0
  fi
  if [[ -z "$image_integrity_status" ]]; then
    image_integrity_status="missing"
  fi
  if [[ -z "$image_integrity_nonblank" ]]; then
    image_integrity_nonblank=false
  fi
  if [[ -z "$image_integrity_distinct" ]]; then
    image_integrity_distinct=0
  fi
  if [[ -z "$image_integrity_non_background" ]]; then
    image_integrity_non_background=0
  fi

  text_resolved_source="missing"
  text_resolved_family="missing"
  text_resolved_path=""
  symbol_resolved_source="missing"
  symbol_resolved_family="missing"
  symbol_resolved_path=""
  font_provenance_status="missing"
  if [[ -f "$visual_run_path" ]]; then
    text_resolved_source="$(awk '/"text":/ { in_text=1; next } in_text && /"symbol":/ { exit } in_text && /"resolvedSource":/ { gsub(/^ *"resolvedSource": "/, ""); gsub(/",?$/, ""); print; exit }' "$visual_run_path")"
    text_resolved_family="$(awk '/"text":/ { in_text=1; next } in_text && /"symbol":/ { exit } in_text && /"resolvedFamily":/ { gsub(/^ *"resolvedFamily": "/, ""); gsub(/",?$/, ""); print; exit }' "$visual_run_path")"
    text_resolved_path="$(awk '/"text":/ { in_text=1; next } in_text && /"symbol":/ { exit } in_text && /"resolvedPath":/ { gsub(/^ *"resolvedPath": "/, ""); gsub(/",?$/, ""); print; exit }' "$visual_run_path")"
    symbol_resolved_source="$(awk '/"symbol":/ { in_symbol=1; next } in_symbol && /"viewport":/ { exit } in_symbol && /"resolvedSource":/ { gsub(/^ *"resolvedSource": "/, ""); gsub(/",?$/, ""); print; exit }' "$visual_run_path")"
    symbol_resolved_family="$(awk '/"symbol":/ { in_symbol=1; next } in_symbol && /"viewport":/ { exit } in_symbol && /"resolvedFamily":/ { gsub(/^ *"resolvedFamily": "/, ""); gsub(/",?$/, ""); print; exit }' "$visual_run_path")"
    symbol_resolved_path="$(awk '/"symbol":/ { in_symbol=1; next } in_symbol && /"viewport":/ { exit } in_symbol && /"resolvedPath":/ { gsub(/^ *"resolvedPath": "/, ""); gsub(/",?$/, ""); print; exit }' "$visual_run_path")"
  fi
  if [[ -z "$text_resolved_source" ]]; then
    text_resolved_source="missing"
  fi
  if [[ -z "$text_resolved_family" ]]; then
    text_resolved_family="missing"
  fi
  if [[ -z "$symbol_resolved_source" ]]; then
    symbol_resolved_source="missing"
  fi
  if [[ -z "$symbol_resolved_family" ]]; then
    symbol_resolved_family="missing"
  fi
  if [[ "$text_resolved_source" == "missing" || "$text_resolved_family" == "missing" || "$symbol_resolved_source" == "missing" || "$symbol_resolved_family" == "missing" ]]; then
    font_provenance_status="failed"
    if [[ ! -f "$visual_run_path" ]]; then
      font_provenance_status="missing"
    fi
  else
    font_provenance_status="passed"
  fi
  case "$font_provenance_status" in
    passed)
      font_passed=$((font_passed + 1))
      ;;
    missing)
      font_missing=$((font_missing + 1))
      ;;
    *)
      font_failed=$((font_failed + 1))
      ;;
  esac

  image_integrity_warning="none"
  if [[ "$image_integrity_status" != "passed" ]]; then
    image_integrity_warning="$image_integrity_status"
  elif awk "BEGIN { exit !($image_integrity_non_background < $low_content_warning_threshold) }"; then
    image_integrity_warning="lowContentWarning"
  fi
  if [[ "$image_integrity_warning" != "none" ]]; then
    image_integrity_warning_count=$((image_integrity_warning_count + 1))
  fi
  image_size_warning="none"
  if [[ "$expected_viewport_width" -le 0 || "$expected_viewport_height" -le 0 || "$actual_image_width" -le 0 || "$actual_image_height" -le 0 ]]; then
    image_size_warning="missing"
  elif [[ "$expected_viewport_width" -ne "$actual_image_width" || "$expected_viewport_height" -ne "$actual_image_height" ]]; then
    image_size_warning="mismatch"
  fi
  if [[ "$image_size_warning" != "none" ]]; then
    image_size_warning_count=$((image_size_warning_count + 1))
  fi
  case "$image_integrity_status" in
    passed)
      image_integrity_passed=$((image_integrity_passed + 1))
      ;;
    missing)
      image_integrity_missing=$((image_integrity_missing + 1))
      ;;
    *)
      image_integrity_failed=$((image_integrity_failed + 1))
      ;;
  esac

  interactions_path="$scenario_output/interactions.json"
  interaction_status="missing"
  interaction_step_count=0
  interaction_passed_count=0
  interaction_failed_count=0
  assert_property_count=0
  route_anchor_warning="none"
  if [[ -f "$interactions_path" ]]; then
    interaction_step_count="$(grep -c '"status":' "$interactions_path" || true)"
    interaction_passed_count="$(grep -c '"status": "passed"' "$interactions_path" || true)"
    interaction_failed_count="$(grep -c '"status": "failed"' "$interactions_path" || true)"
    assert_property_count="$(grep -c '"type": "assertProperty"' "$interactions_path" || true)"
    if [[ "$interaction_failed_count" -ne 0 ]]; then
      interaction_status="failed"
    else
      interaction_status="passed"
    fi
  fi
  if [[ "$assert_property_count" -eq 0 ]]; then
    route_anchor_warning="missing route anchor"
    route_anchor_warning_count=$((route_anchor_warning_count + 1))
    if [[ "$interaction_status" == "passed" ]]; then
      interaction_status="failed"
    fi
  fi
  case "$interaction_status" in
    passed)
      interaction_passed=$((interaction_passed + 1))
      ;;
    missing)
      interaction_missing=$((interaction_missing + 1))
      ;;
    *)
      interaction_failed=$((interaction_failed + 1))
      ;;
  esac

  artifact_status="passed"
  missing_artifact_count=0
  missing_artifacts_json=""
  for expected_artifact in "${expected_artifacts[@]}"; do
    expected_artifact_path="$scenario_output/$expected_artifact"
    if [[ ! -f "$expected_artifact_path" ]]; then
      artifact_status="failed"
      missing_artifact_count=$((missing_artifact_count + 1))
      artifact_missing_total=$((artifact_missing_total + 1))
      if [[ -n "$missing_artifacts_json" ]]; then
        missing_artifacts_json="$missing_artifacts_json,"
      fi
      missing_artifacts_json="$missing_artifacts_json\"$expected_artifact\""
    fi
  done
  if [[ "$artifact_status" == "passed" ]]; then
    artifact_passed=$((artifact_passed + 1))
  else
    artifact_failed=$((artifact_failed + 1))
  fi

  cat >> "$tmp_entries" <<ENTRY
{"scenario":"$scenario","status":"$status","message":"$message","output":"$scenario_output","log":"$log_path","screenshot":"$scenario_output/visual/mac-runtime.png","scenarioCoverage":{"group":"$coverage_group","surface":"$coverage_surface"},"artifactSummary":{"status":"$artifact_status","expectedArtifactCount":${#expected_artifacts[@]},"missingArtifactCount":$missing_artifact_count,"missingArtifacts":[$missing_artifacts_json],"run":"$scenario_output/run.json","tree":"$scenario_output/tree.json","accessibility":"$scenario_output/accessibility.json","interactions":"$scenario_output/interactions.json","visualRun":"$scenario_output/visual/visual-run.json","screenshot":"$scenario_output/visual/mac-runtime.png"},"fontSummary":{"status":"$font_provenance_status","textResolvedSource":"$text_resolved_source","textResolvedFamily":"$text_resolved_family","textResolvedPath":"$text_resolved_path","symbolResolvedSource":"$symbol_resolved_source","symbolResolvedFamily":"$symbol_resolved_family","symbolResolvedPath":"$symbol_resolved_path","visualRun":"$visual_run_path"},"windowsScreenshotSummary":{"status":"$windows_screenshot_status","source":"$windows_screenshot_source","screenshot":"$windows_screenshot_path"},"interactionSummary":{"status":"$interaction_status","stepCount":$interaction_step_count,"passedCount":$interaction_passed_count,"failedCount":$interaction_failed_count,"assertPropertyCount":$assert_property_count,"routeAnchorWarning":"$route_anchor_warning","interactions":"$interactions_path"},"runtimeImageIntegrity":{"status":"$image_integrity_status","isNonBlank":$image_integrity_nonblank,"distinctColorCount":$image_integrity_distinct,"nonBackgroundPixelPercentage":$image_integrity_non_background,"imageIntegrityWarning":"$image_integrity_warning","lowContentWarningThreshold":$low_content_warning_threshold,"expectedViewport":{"width":$expected_viewport_width,"height":$expected_viewport_height},"actualImageSize":{"width":$actual_image_width,"height":$actual_image_height},"imageSizeWarning":"$image_size_warning","visualRun":"$visual_run_path"},"nativeComparison":{"status":"$comparison_status","reason":"$comparison_reason","reference":"$scenario_reference","windowsReference":"$scenario_output/visual/windows-reference.png","macRuntime":"$scenario_output/visual/mac-runtime.png","pixelDiffImage":"$scenario_output/visual/pixel-diff.png","pixelDiff":"$scenario_output/visual/pixel-diff.json"}}
ENTRY
  cat >> "$tmp_groups" <<ENTRY
{"group":"$coverage_group","surface":"$coverage_surface","scenario":"$scenario","status":"$status","screenshot":"$scenario_output/visual/mac-runtime.png"}
ENTRY
  printf '%s\n' "$coverage_group" >> "$tmp_found_groups"
done

ended_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
