  echo "interactionMissing: $interaction_missing scenario interaction report(s) were missing" >&2
  exit 1
fi
if [[ $interaction_failed -ne 0 ]]; then
  echo "interaction failed: $interaction_failed scenario interaction report(s) failed or had no route anchor" >&2
  exit 1
fi
if [[ $artifact_failed -ne 0 ]]; then
  echo "artifact completeness failed: $artifact_failed scenario(s), $artifact_missing_total missing artifact(s)" >&2
  exit 1
fi
if [[ $font_failed -ne 0 || $font_missing -ne 0 ]]; then
  echo "font provenance failed: $font_failed failed, $font_missing missing scenario font diagnostic(s)" >&2
  exit 1
fi
if [[ "$coverage_complete" != "true" ]]; then
  echo "coverage is incomplete: $missing_scenario_group_count missing scenario group(s)" >&2
  exit 1
fi
if [[ "$require_native_comparison" == "true" && "$native_comparison_status" != "passed" ]]; then
  exit 1
fi
