#!/usr/bin/env bash
set -u -o pipefail

usage() {
  cat <<'USAGE'
Usage: winui3-mac-runner-downstream-windows-probe-sweep [--output <dir>] [--reference <png-or-native-reference-dir>] [--require-native-comparison]

Runs every MeetingChallenge Windows macOS runtime probe scenario with
skia-v2 strict visual mode and writes summary.json, summary.md, and review.html.
When --reference points to a normalized native-reference-import directory, each
scenario is compared against its matching Windows reference image.
Use --require-native-comparison in CI/release gates to fail when any native
comparison is skipped or failed.
USAGE
}

output="/private/tmp/emsi-windows-probe-sweep"
reference=""
require_native_comparison=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --output)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for --output" >&2
        exit 2
      fi
      output="$2"
      shift 2
      ;;
    --reference)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for --reference" >&2
        exit 2
      fi
      reference="$2"
      shift 2
      ;;
    --require-native-comparison)
      require_native_comparison=true
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
runtime_root="$(cd "$script_dir/.." && pwd)"
monorepo_root="$(cd "$runtime_root/../.." && pwd)"
probe_root="$monorepo_root/apps/windows/tests/MeetingChallenge.WinUI.MacRuntimeProbe"
project="$probe_root/MeetingChallenge.WinUI.MacRuntimeProbe.csproj"
scenario_dir="$probe_root/scenarios"
runner="$runtime_root/tools/winui3-mac-runner"

scenarios=(
  "login-light.json"
  "shell-staff-light.json"
  "messages-multiline-light.json"
  "admin-dashboard-light.json"
  "admin-workbench-light.json"
  "command-search-light.json"
  "status-states-light.json"
  "settings-profile-light.json"
)

mkdir -p "$output"
summary_json="$output/summary.json"
summary_md="$output/summary.md"
review_html="$output/review.html"
tmp_entries="$output/.summary-entries.jsonl"
: > "$tmp_entries"

passed=0
failed=0
native_comparison_status="skipped"
native_comparison_reason="No Windows reference image was provided."
native_comparison_passed=0
native_comparison_failed=0
native_comparison_skipped=0
reference_readiness_status="not-requested"
reference_readiness_reason="No Windows reference image was requested."
missing_reference_count=0
missing_references_json=""
image_integrity_passed=0
image_integrity_failed=0
image_integrity_missing=0
started_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

for scenario in "${scenarios[@]}"; do
  scenario_path="$scenario_dir/$scenario"
  scenario_name="${scenario%.json}"
  scenario_output="$output/$scenario_name"
  log_path="$scenario_output/strict-scenario.log"
  mkdir -p "$scenario_output"

  if [[ ! -f "$scenario_path" ]]; then
    status="failed"
    failed=$((failed + 1))
    message="missing scenario file"
    printf '%s\n' "$message" > "$log_path"
  else
    if [[ -n "$reference" ]]; then
      "$runner" run \
        --project "$project" \
        --renderer skia-v2 \
        --scenario "$scenario_path" \
        --strict-visual \
        --output "$scenario_output" \
        --reference "$reference" \
        > "$log_path" 2>&1
    else
      "$runner" run \
        --project "$project" \
        --renderer skia-v2 \
        --scenario "$scenario_path" \
        --strict-visual \
        --output "$scenario_output" \
        > "$log_path" 2>&1
    fi
    exit_code=$?
    if [[ $exit_code -eq 0 ]]; then
      status="passed"
      passed=$((passed + 1))
      message="strict visual scenario passed"
    else
      status="failed"
      failed=$((failed + 1))
      message="strict visual scenario failed with exit code $exit_code"
    fi
  fi

  pixel_diff_path="$scenario_output/visual/pixel-diff.json"
  if [[ -f "$pixel_diff_path" ]]; then
    comparison_status="$(sed -n 's/.*"status": "\([^"]*\)".*/\1/p' "$pixel_diff_path" | head -1)"
    comparison_reason="$(sed -n 's/.*"reason": "\([^"]*\)".*/\1/p' "$pixel_diff_path" | head -1)"
  else
    comparison_status="$native_comparison_status"
    comparison_reason="$native_comparison_reason"
  fi
  if [[ -z "$comparison_status" ]]; then
    comparison_status="$native_comparison_status"
  fi
  if [[ -z "$comparison_reason" ]]; then
    comparison_reason="$native_comparison_reason"
  fi
  case "$comparison_status" in
    passed)
      native_comparison_passed=$((native_comparison_passed + 1))
      ;;
    failed)
      native_comparison_failed=$((native_comparison_failed + 1))
      ;;
    *)
      native_comparison_skipped=$((native_comparison_skipped + 1))
      ;;
  esac

  reference_problem=""
  if [[ -n "$reference" && ! -f "$pixel_diff_path" ]]; then
    if [[ ! -e "$reference" ]]; then
      reference_problem="Reference image or directory was not found: $reference"
    elif grep -q "No native WinUI reference image" "$log_path"; then
      reference_problem="$(grep -m 1 "No native WinUI reference image" "$log_path")"
    elif grep -q "Reference image or directory was not found" "$log_path"; then
      reference_problem="$(grep -m 1 "Reference image or directory was not found" "$log_path")"
    elif grep -q "Imported native reference image from manifest was not found" "$log_path"; then
      reference_problem="$(grep -m 1 "Imported native reference image from manifest was not found" "$log_path")"
    fi
  fi
  if [[ -n "$reference_problem" ]]; then
    missing_reference_count=$((missing_reference_count + 1))
    escaped_problem="${reference_problem//\\/\\\\}"
    escaped_problem="${escaped_problem//\"/\\\"}"
    escaped_log="${log_path//\\/\\\\}"
    escaped_log="${escaped_log//\"/\\\"}"
    if [[ -n "$missing_references_json" ]]; then
      missing_references_json="$missing_references_json,"
    fi
    missing_references_json="$missing_references_json{\"scenario\":\"$scenario\",\"reason\":\"$escaped_problem\",\"log\":\"$escaped_log\"}"
  fi

  visual_run_path="$scenario_output/visual/visual-run.json"
  image_integrity_status="missing"
  image_integrity_nonblank=false
  image_integrity_distinct=0
  image_integrity_non_background=0
  if [[ -f "$visual_run_path" ]]; then
    image_integrity_status="$(awk '/"runtimeImageIntegrity":/ { in_integrity=1; next } in_integrity && /"status":/ { gsub(/[",]/, "", $2); print $2; exit }' "$visual_run_path")"
    image_integrity_nonblank="$(awk '/"runtimeImageIntegrity":/ { in_integrity=1; next } in_integrity && /"isNonBlank":/ { gsub(/[",]/, "", $2); print $2; exit }' "$visual_run_path")"
    image_integrity_distinct="$(awk '/"runtimeImageIntegrity":/ { in_integrity=1; next } in_integrity && /"distinctColorCount":/ { gsub(/[",]/, "", $2); print $2; exit }' "$visual_run_path")"
    image_integrity_non_background="$(awk '/"runtimeImageIntegrity":/ { in_integrity=1; next } in_integrity && /"nonBackgroundPixelPercentage":/ { gsub(/[",]/, "", $2); print $2; exit }' "$visual_run_path")"
  fi
  if [[ -z "$image_integrity_status" ]]; then
    image_integrity_status="missing"
  fi
  if [[ -z "$image_integrity_nonblank" ]]; then
    image_integrity_nonblank=false
  fi
  if [[ -z "$image_integrity_distinct" ]]; then
    image_integrity_distinct=0
  fi
  if [[ -z "$image_integrity_non_background" ]]; then
    image_integrity_non_background=0
  fi
  case "$image_integrity_status" in
    passed)
      image_integrity_passed=$((image_integrity_passed + 1))
      ;;
    missing)
      image_integrity_missing=$((image_integrity_missing + 1))
      ;;
    *)
      image_integrity_failed=$((image_integrity_failed + 1))
      ;;
  esac

  cat >> "$tmp_entries" <<ENTRY
{"scenario":"$scenario","status":"$status","message":"$message","output":"$scenario_output","log":"$log_path","screenshot":"$scenario_output/visual/mac-runtime.png","runtimeImageIntegrity":{"status":"$image_integrity_status","isNonBlank":$image_integrity_nonblank,"distinctColorCount":$image_integrity_distinct,"nonBackgroundPixelPercentage":$image_integrity_non_background,"visualRun":"$visual_run_path"},"nativeComparison":{"status":"$comparison_status","reason":"$comparison_reason","pixelDiff":"$pixel_diff_path"}}
ENTRY
done

ended_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
overall_status="passed"
if [[ $failed -ne 0 ]]; then
  overall_status="failed"
fi
if [[ -n "$reference" ]]; then
  if [[ ! -e "$reference" ]]; then
    reference_readiness_status="missing"
    reference_readiness_reason="Reference path was not found."
  elif [[ $missing_reference_count -ne 0 ]]; then
    reference_readiness_status="missing"
    reference_readiness_reason="$missing_reference_count scenario reference(s) were missing or unresolved."
  else
    reference_readiness_status="ready"
    reference_readiness_reason="Reference path was provided and no missing per-scenario reference was detected."
  fi
fi
if [[ $native_comparison_failed -ne 0 ]]; then
  native_comparison_status="failed"
  native_comparison_reason="$native_comparison_failed native comparison(s) failed."
elif [[ -n "$reference" && $native_comparison_skipped -eq 0 ]]; then
  native_comparison_status="passed"
  native_comparison_reason="All scenarios were compared against Windows reference images."
fi
if [[ "$require_native_comparison" == "true" && "$native_comparison_status" != "passed" ]]; then
  overall_status="failed"
  if [[ $native_comparison_skipped -ne 0 ]]; then
    native_comparison_reason="native comparison is required, but $native_comparison_skipped scenario(s) were skipped."
  fi
fi

{
  echo "{"
  echo "  \"schemaVersion\": \"0.1\","
  echo "  \"status\": \"$overall_status\","
  echo "  \"startedAt\": \"$started_at\","
  echo "  \"endedAt\": \"$ended_at\","
  echo "  \"project\": \"$project\","
  echo "  \"scenarioDirectory\": \"$scenario_dir\","
  echo "  \"summary\": {"
  echo "    \"total\": ${#scenarios[@]},"
  echo "    \"passed\": $passed,"
  echo "    \"failed\": $failed,"
  echo "    \"imageIntegrityPassed\": $image_integrity_passed,"
  echo "    \"imageIntegrityFailed\": $image_integrity_failed,"
  echo "    \"imageIntegrityMissing\": $image_integrity_missing"
  echo "  },"
  echo "  \"referenceReadiness\": {"
  echo "    \"status\": \"$reference_readiness_status\","
  echo "    \"reason\": \"$reference_readiness_reason\","
  echo "    \"reference\": \"$reference\","
  echo "    \"missingReferenceCount\": $missing_reference_count,"
  echo "    \"missingReferences\": ["
  if [[ -n "$missing_references_json" ]]; then
    printf '      %s\n' "$missing_references_json"
  fi
  echo "    ]"
  echo "  },"
  echo "  \"nativeComparison\": {"
  echo "    \"status\": \"$native_comparison_status\","
  echo "    \"reason\": \"$native_comparison_reason\","
  echo "    \"reference\": \"$reference\","
  echo "    \"required\": $require_native_comparison,"
  echo "    \"passed\": $native_comparison_passed,"
  echo "    \"failed\": $native_comparison_failed,"
  echo "    \"skipped\": $native_comparison_skipped,"
  echo "    \"interpretation\": \"This sweep proves macOS runtime rendering, diagnostics, and screenshot generation for the listed downstream Windows probe scenarios. It does not prove native Windows pixel parity until Windows reference images are supplied.\""
  echo "  },"
  echo "  \"scenarios\": ["
  entry_count=0
  while IFS= read -r entry; do
    entry_count=$((entry_count + 1))
    if [[ $entry_count -gt 1 ]]; then
      echo ","
    fi
    printf '    %s' "$entry"
  done < "$tmp_entries"
  echo
  echo "  ]"
  echo "}"
} > "$summary_json"

{
  echo "# Downstream Windows Probe Sweep"
  echo
  echo "- status: $overall_status"
  echo "- total: ${#scenarios[@]}"
  echo "- passed: $passed"
  echo "- failed: $failed"
  echo "- image integrity: $image_integrity_passed passed, $image_integrity_failed failed, $image_integrity_missing missing"
  echo "- reference readiness: $reference_readiness_status ($reference_readiness_reason)"
  echo "- missing references: $missing_reference_count"
  echo "- native comparison: $native_comparison_status ($native_comparison_reason)"
  echo "- native comparison required: $require_native_comparison"
  echo
  echo "> This sweep proves macOS runtime rendering, diagnostics, and screenshot generation. It does not prove native Windows pixel parity until Windows reference images are supplied."
  echo
  echo "| Scenario | Status | Image integrity | Native comparison | Screenshot | Log |"
  echo "| --- | --- | --- | --- | --- | --- |"
  while IFS= read -r entry; do
    scenario="$(printf '%s' "$entry" | sed -E 's/.*"scenario":"([^"]+)".*/\1/')"
    status="$(printf '%s' "$entry" | sed -E 's/.*"scenario":"[^"]+","status":"([^"]+)".*/\1/')"
    image_integrity_status="$(printf '%s' "$entry" | sed -E 's/.*"runtimeImageIntegrity":\{"status":"([^"]+)".*/\1/')"
    image_integrity_distinct="$(printf '%s' "$entry" | sed -E 's/.*"distinctColorCount":([^,}]+).*/\1/')"
    image_integrity_non_background="$(printf '%s' "$entry" | sed -E 's/.*"nonBackgroundPixelPercentage":([^,}]+).*/\1/')"
    comparison_status="$(printf '%s' "$entry" | sed -E 's/.*"nativeComparison":\{"status":"([^"]+)".*/\1/')"
    scenario_output="$(printf '%s' "$entry" | sed -E 's/.*"output":"([^"]+)".*/\1/')"
    log_path="$(printf '%s' "$entry" | sed -E 's/.*"log":"([^"]+)".*/\1/')"
    echo "| $scenario | $status | $image_integrity_status (${image_integrity_distinct} colors, ${image_integrity_non_background}% non-bg) | $comparison_status | $scenario_output/visual/mac-runtime.png | $log_path |"
  done < "$tmp_entries"
} > "$summary_md"

{
  cat <<HTML
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Downstream Windows Probe Sweep</title>
  <style>
    body {
      margin: 24px;
      background: #f7f8fa;
      color: #111827;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    h1 {
      margin: 0 0 8px;
      font-size: 28px;
      line-height: 1.2;
    }

    a {
      color: #155eef;
    }

    .summary {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin: 20px 0;
    }

    .summary div,
    .card {
      background: #ffffff;
      border: 1px solid #d6dae2;
      border-radius: 8px;
      box-shadow: 0 1px 2px rgb(17 24 39 / 6%);
    }

    .summary div {
      min-width: 96px;
      padding: 10px 14px;
      color: #4b5563;
      font-size: 13px;
    }

    .summary strong {
      display: block;
      margin-top: 2px;
      color: #111827;
      font-size: 22px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
      gap: 16px;
    }

    .card {
      padding: 12px;
    }

    .card h2 {
      margin: 0 0 10px;
      font-size: 15px;
      line-height: 1.35;
    }

    .card img {
      display: block;
      width: 100%;
      height: auto;
      background: #ffffff;
      border: 1px solid #e5e7eb;
      border-radius: 6px;
    }

    .meta {
      margin: 10px 0 0;
      color: #4b5563;
      font-size: 13px;
    }

    .status-passed {
      color: #0f7b26;
      font-weight: 700;
    }

    .status-failed {
      color: #b91c1c;
      font-weight: 700;
    }

    .notice {
      margin: 0 0 20px;
      padding: 12px 14px;
      background: #fff7ed;
      border: 1px solid #fdba74;
      border-radius: 8px;
      color: #7c2d12;
      font-size: 14px;
      line-height: 1.45;
    }
  </style>
</head>
<body>
  <header>
    <h1>Downstream Windows Probe Sweep</h1>
    <p>Status: <strong class="status-$overall_status">$overall_status</strong></p>
    <p><a href="summary.json">summary.json</a> | <a href="summary.md">summary.md</a></p>
  </header>
  <section class="summary" aria-label="Sweep summary">
    <div>Total<strong>${#scenarios[@]}</strong></div>
    <div>Passed<strong>$passed</strong></div>
    <div>Failed<strong>$failed</strong></div>
    <div>Image integrity<strong>$image_integrity_passed/$image_integrity_failed/$image_integrity_missing</strong></div>
    <div>Reference readiness<strong>$reference_readiness_status</strong></div>
    <div>Native comparison<strong>$native_comparison_status</strong></div>
    <div>Required<strong>$require_native_comparison</strong></div>
  </section>
  <section class="notice" aria-label="Reference readiness">
    <strong>Reference readiness: $reference_readiness_status.</strong>
    $reference_readiness_reason Missing references: $missing_reference_count.
  </section>
  <section class="notice" aria-label="Native comparison status">
    <strong>Native comparison: $native_comparison_status.</strong>
    $native_comparison_reason This sweep proves macOS runtime rendering, diagnostics, and screenshot generation; it does not prove native Windows pixel parity until Windows reference images are supplied.
  </section>
  <section class="grid" aria-label="Scenario screenshots">
HTML

  while IFS= read -r entry; do
    scenario="$(printf '%s' "$entry" | sed -E 's/.*"scenario":"([^"]+)".*/\1/')"
    status="$(printf '%s' "$entry" | sed -E 's/.*"scenario":"[^"]+","status":"([^"]+)".*/\1/')"
    image_integrity_status="$(printf '%s' "$entry" | sed -E 's/.*"runtimeImageIntegrity":\{"status":"([^"]+)".*/\1/')"
    image_integrity_distinct="$(printf '%s' "$entry" | sed -E 's/.*"distinctColorCount":([^,}]+).*/\1/')"
    image_integrity_non_background="$(printf '%s' "$entry" | sed -E 's/.*"nonBackgroundPixelPercentage":([^,}]+).*/\1/')"
    comparison_status="$(printf '%s' "$entry" | sed -E 's/.*"nativeComparison":\{"status":"([^"]+)".*/\1/')"
    comparison_reason="$(printf '%s' "$entry" | sed -E 's/.*"nativeComparison":\{"status":"[^"]+","reason":"([^"]+)".*/\1/')"
    scenario_name="${scenario%.json}"
    cat <<HTML
    <article class="card">
      <h2>$scenario</h2>
      <img src="$scenario_name/visual/mac-runtime.png" alt="$scenario screenshot">
      <p class="meta">Status: <span class="status-$status">$status</span> | Native comparison: $comparison_status | <a href="$scenario_name/strict-scenario.log">log</a> | <a href="$scenario_name/visual/visual-run.json">visual-run</a> | <a href="$scenario_name/visual/pixel-diff.json">pixel-diff</a></p>
      <p class="meta">Image integrity: $image_integrity_status (${image_integrity_distinct} colors, ${image_integrity_non_background}% non-background)</p>
      <p class="meta">$comparison_reason</p>
    </article>
HTML
  done < "$tmp_entries"

  cat <<HTML
  </section>
</body>
</html>
HTML
} > "$review_html"

rm -f "$tmp_entries"

echo "downstream-windows-probe-sweep: $overall_status ($passed passed, $failed failed)"
echo "summary.json: $summary_json"
echo "summary.md: $summary_md"
echo "review.html: $review_html"
echo "reference-readiness: $reference_readiness_status ($missing_reference_count missing)"

if [[ $failed -ne 0 ]]; then
  exit 1
fi
if [[ "$require_native_comparison" == "true" && "$native_comparison_status" != "passed" ]]; then
  exit 1
fi
