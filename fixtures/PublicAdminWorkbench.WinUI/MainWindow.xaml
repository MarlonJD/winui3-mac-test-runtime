<Window
    x:Class="PublicAdminWorkbench.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Public Admin Workbench">
    <NavigationView
        x:Name="RootNavigation"
        x:Uid="RootNavigation"
        Background="#F7F8FA"
        CompactPaneLength="56"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        OpenPaneLength="248"
        PaneDisplayMode="Left"
        SelectionChanged="OnNavigationSelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="OverviewNavigationItem" Content="Settings home" Tag="overview">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE80F;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="QueueNavigationItem" Content="Policies" Tag="queue">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE8A5;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="ReportsNavigationItem" Content="Audit" Tag="reports">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE9D2;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <NavigationView.PaneFooter>
            <StackPanel Padding="12,8,12,12" Spacing="8">
                <Border x:Name="AccountFooter">
                    <Grid ColumnDefinitions="32,*" ColumnSpacing="10">
                        <Border>
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="15"
                                Foreground="#2562D9"
                                Glyph="&#xE77B;" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                            <TextBlock x:Name="AccountDisplayNameTextBlock" Text="Policy Admin" />
                            <TextBlock x:Name="AccountUsernameTextBlock" Text="public.policy" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Button
                    x:Name="RefreshButton"
                    HorizontalAlignment="Stretch"
                    Click="OnRefreshClicked"
                    Content="Reset" />
            </StackPanel>
        </NavigationView.PaneFooter>

        <Frame x:Name="WorkbenchFrame">
            <Frame.Content>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Padding="24,20,24,24" Spacing="14">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                            <StackPanel Spacing="2">
                                <TextBlock x:Name="WorkbenchTitleText" Text="Policy editor" />
                                <TextBlock Text="Configure public access, review workflow, and audit settings." />
                            </StackPanel>
                            <CommandBar x:Name="DecisionCommandBar" Grid.Column="1">
                                <CommandBar.PrimaryCommands>
                                    <AppBarButton x:Name="ApproveCommand" Label="Apply" Click="OnApproveClicked">
                                        <AppBarButton.Icon>
                                            <FontIcon Glyph="&#xE73E;" />
                                        </AppBarButton.Icon>
                                    </AppBarButton>
                                    <AppBarButton x:Name="DeferCommand" Label="Validate" Click="OnDeferClicked">
                                        <AppBarButton.Icon>
                                            <FontIcon Glyph="&#xE8FB;" />
                                        </AppBarButton.Icon>
                                    </AppBarButton>
                                </CommandBar.PrimaryCommands>
                            </CommandBar>
                        </Grid>

                        <InfoBar
                            x:Name="WorkbenchStatus"
                            IsOpen="True"
                            Message="Two policy settings require validation before publishing."
                            Severity="Warning"
                            Title="Review required" />

                        <Grid ColumnDefinitions="260,180,*,140" ColumnSpacing="12">
                            <TextBox
                                x:Name="PolicySearchBox"
                                AutomationProperties.Name="Search policies"
                                Text="Search policies" />
                            <ComboBox
                                x:Name="PolicyScopeComboBox"
                                Grid.Column="1"
                                PlaceholderText="Scope" />
                            <TextBlock
                                x:Name="PolicyValidationText"
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Text="2 settings need validation" />
                            <ProgressBar
                                x:Name="PolicyCompletenessProgress"
                                Grid.Column="3"
                                Maximum="100"
                                Minimum="0"
                                Value="72" />
                        </Grid>

                        <Grid ColumnDefinitions="280,*" ColumnSpacing="20">
                            <ListView x:Name="PolicyListView" SelectedIndex="0">
                                <ListView.Items>
                                    <TextBlock Text="External access policy" />
                                    <TextBlock Text="Publishing approval policy" />
                                    <TextBlock Text="Audit retention policy" />
                                    <TextBlock Text="Notification policy" />
                                </ListView.Items>
                            </ListView>

                            <StackPanel
                                x:Name="PolicyDetailPanel"
                                Grid.Column="1"
                                Spacing="12">
                                <StackPanel x:Name="AccessPolicySection" Spacing="8">
                                    <TextBlock Text="Access policy" />
                                    <Grid ColumnDefinitions="220,*" ColumnSpacing="12">
                                        <TextBlock VerticalAlignment="Center" Text="Policy name" />
                                        <TextBox
                                            x:Name="PolicyNameTextBox"
                                            Grid.Column="1"
                                            Text="External access review" />
                                    </Grid>
                                    <Grid ColumnDefinitions="220,*" ColumnSpacing="12">
                                        <TextBlock VerticalAlignment="Center" Text="Owner group" />
                                        <ComboBox
                                            x:Name="PolicyOwnerComboBox"
                                            Grid.Column="1"
                                            PlaceholderText="Select owner" />
                                    </Grid>
                                    <CheckBox
                                        x:Name="RequireManagerApprovalCheckBox"
                                        Content="Require manager approval"
                                        IsChecked="True" />
                                </StackPanel>

                                <StackPanel x:Name="ReviewPolicySection" Spacing="8">
                                    <TextBlock Text="Review workflow" />
                                    <ContentControl x:Name="AuditLoggingToggleSwitch" />
                                    <Grid ColumnDefinitions="220,*" ColumnSpacing="12">
                                        <TextBlock VerticalAlignment="Center" Text="Review window" />
                                        <ContentControl
                                            x:Name="ReviewWindowSlider"
                                            Grid.Column="1" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel x:Name="RiskPolicySection" Spacing="8">
                                    <TextBlock Text="Risk level" />
                                    <RadioButton
                                        x:Name="RiskLowRadioButton"
                                        Content="Low risk"
                                        GroupName="RiskLevel"
                                        IsChecked="True" />
                                    <RadioButton
                                        x:Name="RiskHighRadioButton"
                                        Content="High risk"
                                        GroupName="RiskLevel" />
                                </StackPanel>

                                <Button
                                    x:Name="CompleteReviewButton"
                                    HorizontalAlignment="Stretch"
                                    Click="OnApproveClicked"
                                    Content="Publish policy" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Frame.Content>
        </Frame>
    </NavigationView>
</Window>
