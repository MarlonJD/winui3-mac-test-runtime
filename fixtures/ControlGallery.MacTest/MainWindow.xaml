<Window
    x:Class="ControlGallery.MacTest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Public Control Gallery">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel x:Name="RootStack" Padding="24,24,24,24" Spacing="12">
      <TextBlock Text="Control gallery" AutomationProperties.Name="Control gallery title" />
      <InfoBar
          x:Name="StatusInfo"
          IsOpen="True"
          Message="Generic public fixture state"
          Severity="Success"
          Title="Ready" />
      <TextBox x:Name="SearchBox" Text="Operations" AutomationProperties.Name="Filter controls" />
      <ComboBox x:Name="StatusComboBox" PlaceholderText="Status" SelectedIndex="1" />
      <CheckBox x:Name="EnabledCheckBox" Content="Enabled" IsChecked="True" />
      <RadioButton x:Name="PriorityHighRadio" Content="High priority" GroupName="Priority" IsChecked="True" />
      <ToggleButton x:Name="PinnedToggle" Content="Pinned" IsChecked="True" />
      <ProgressBar x:Name="CompletionProgress" Minimum="0" Maximum="100" Value="65" />
      <ProgressRing x:Name="RefreshProgress" IsActive="True" />
      <CommandBar x:Name="CommandSurface">
        <CommandBar.PrimaryCommands>
          <AppBarButton x:Name="SaveCommand" Label="Save" Click="OnSaveClicked" />
        </CommandBar.PrimaryCommands>
      </CommandBar>
      <ItemsControl x:Name="SummaryItems" />
      <ListView x:Name="RecentItems" />
      <ContentControl x:Name="DetailContent">
        <TextBlock Text="Detail content host" />
      </ContentControl>
    </StackPanel>
  </ScrollViewer>
</Window>
