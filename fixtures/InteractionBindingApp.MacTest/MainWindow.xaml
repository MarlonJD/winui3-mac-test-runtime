<Window
    x:Class="InteractionBindingApp.MacTest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Interaction Binding App">
  <StackPanel x:Name="RootStack" Spacing="8">
    <TextBlock x:Name="TitleText" Text="{Binding Title}" />
    <Button x:Name="RefreshButton" Content="{Binding ButtonLabel}" Click="OnRefreshClicked" />
    <Frame x:Name="DetailsFrame" />
  </StackPanel>
</Window>
