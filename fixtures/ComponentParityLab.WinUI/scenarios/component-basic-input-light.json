{
  "schemaVersion": "0.1",
  "fixtureName": "component-parity-lab",
  "name": "component-basic-input-light",
  "viewport": {
    "width": 1028,
    "height": 720
  },
  "scale": 1.0,
  "theme": "light",
  "strictVisual": true,
  "thresholds": {
    "changedPixelPercentage": 18.0,
