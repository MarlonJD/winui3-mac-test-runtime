<Application
    x:Class="ComponentParityLab.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <x:String x:Key="LabThemeName">Light</x:String>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <x:String x:Key="LabThemeName">Dark</x:String>
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <x:String x:Key="LabThemeName">High contrast</x:String>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <SolidColorBrush x:Key="LabAccentBrush" Color="#2562D9" />
            <SolidColorBrush x:Key="LabSurfaceBrush" Color="#FFFFFF" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
