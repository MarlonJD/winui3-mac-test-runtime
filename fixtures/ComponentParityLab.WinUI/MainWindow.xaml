<Window
    x:Class="ComponentParityLab.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Component Parity Lab">
    <NavigationView
        x:Name="RootNavigation"
        CompactPaneLength="56"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        OpenPaneLength="256"
        PaneDisplayMode="Left"
        SelectionChanged="OnNavigationSelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="BasicInputNavigationItem" Content="Basic input" Tag="basic" />
            <NavigationViewItem x:Name="TextFormsNavigationItem" Content="Text and forms" Tag="text" />
            <NavigationViewItem x:Name="CollectionsNavigationItem" Content="Collections" Tag="collections" />
            <NavigationViewItem x:Name="DialogsNavigationItem" Content="Dialogs and flyouts" Tag="dialogs" />
            <NavigationViewItem x:Name="CommandsNavigationItem" Content="Commands and menus" Tag="commands" />
            <NavigationViewItem x:Name="NavigationWorkbenchNavigationItem" Content="Navigation" Tag="navigation" />
            <NavigationViewItem x:Name="StatusPickersNavigationItem" Content="Status and pickers" Tag="status" />
            <NavigationViewItem x:Name="LayoutMediaNavigationItem" Content="Layout and media" Tag="layout" />
        </NavigationView.MenuItems>
        <NavigationView.PaneFooter>
            <StackPanel x:Name="LabPaneFooter" Padding="12,8,12,12" Spacing="8">
                <TextBlock x:Name="PaneFooterTitle" Text="Public fixture" />
                <Button x:Name="ResetLabButton" Content="Reset page" Click="OnResetClicked" />
            </StackPanel>
        </NavigationView.PaneFooter>
        <Frame x:Name="LabFrame" />
    </NavigationView>
</Window>
