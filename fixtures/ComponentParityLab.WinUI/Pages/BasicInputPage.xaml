<Page
    x:Class="ComponentParityLab.WinUI.BasicInputPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel x:Name="BasicInputRoot" Padding="24,20,24,24" Spacing="10">
        <TextBlock x:Name="BasicInputTitle" Text="Page 1: Basic input" />
        <Button x:Name="PrimaryActionButton" Content="Run primary action" Click="OnPrimaryActionClicked" />
        <ToggleButton x:Name="PinnedToggleButton" Content="Pinned" IsChecked="True" Click="OnPinnedClicked" />
        <CheckBox x:Name="EnabledCheckBox" Content="Enabled" IsChecked="True" />
        <RadioButton x:Name="HighPriorityRadioButton" Content="High priority" GroupName="Priority" IsChecked="True" />
        <ComboBox x:Name="StatusComboBox" PlaceholderText="Status" SelectedIndex="0" />
        <TextBlock x:Name="BasicInputStateText" Text="Ready" />
        <StackPanel Orientation="Horizontal" Spacing="14">
            <ContentControl x:Name="DiagnosticRepeatButton" />
            <ContentControl x:Name="DiagnosticHyperlinkButton" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="14">
            <ContentControl x:Name="DiagnosticDropDownButton" />
            <ContentControl x:Name="DiagnosticSplitButton" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="14">
            <ContentControl x:Name="DiagnosticToggleSplitButton" />
            <ContentControl x:Name="DiagnosticSlider" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="14">
            <ContentControl x:Name="DiagnosticToggleSwitch" />
            <ContentControl x:Name="DiagnosticRatingControl" />
        </StackPanel>
    </StackPanel>
</Page>
