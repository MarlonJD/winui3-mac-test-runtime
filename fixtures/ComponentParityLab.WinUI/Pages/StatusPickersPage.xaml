<Page
    x:Class="ComponentParityLab.WinUI.StatusPickersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel x:Name="StatusPickersRoot" Padding="24,20,24,24" Spacing="10">
        <TextBlock x:Name="StatusPickersTitle" Text="Page 7: Status, progress, pickers, people" />
        <InfoBar x:Name="StatusInfoBar" IsOpen="True" Message="Public lab status is ready." Severity="Informational" Title="Ready" />
        <ProgressBar x:Name="CompletionProgressBar" Minimum="0" Maximum="100" Value="62" />
        <ProgressRing x:Name="LoadingProgressRing" IsActive="True" />
        <Button x:Name="CompleteStatusButton" Content="Complete" Click="OnCompleteClicked" />
        <StackPanel Orientation="Horizontal" Spacing="14">
            <ContentControl x:Name="DiagnosticInfoBadge" />
            <ContentControl x:Name="DiagnosticPersonPicture" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="14">
            <ContentControl x:Name="DiagnosticColorPicker" />
            <ContentControl x:Name="DiagnosticCalendarDatePicker" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="14">
            <ContentControl x:Name="DiagnosticCalendarView" />
            <ContentControl x:Name="DiagnosticDatePicker" />
        </StackPanel>
        <ContentControl x:Name="DiagnosticTimePicker" />
    </StackPanel>
</Page>
