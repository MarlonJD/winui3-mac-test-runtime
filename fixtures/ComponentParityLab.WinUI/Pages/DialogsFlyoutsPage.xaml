<Page
    x:Class="ComponentParityLab.WinUI.DialogsFlyoutsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel x:Name="DialogsFlyoutsRoot" Padding="24,20,24,24" Spacing="10">
        <TextBlock x:Name="DialogsFlyoutsTitle" Text="Page 4: Dialogs and flyouts" />
        <StackPanel Orientation="Horizontal" Spacing="14">
            <ContentControl x:Name="DiagnosticContentDialog" />
            <ContentControl x:Name="DiagnosticFlyout" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="14">
            <ContentControl x:Name="DiagnosticTeachingTip" />
            <ContentControl x:Name="DiagnosticToolTip" />
        </StackPanel>
        <ContentControl x:Name="DiagnosticToolTipServiceSetToolTip" />
    </StackPanel>
</Page>
