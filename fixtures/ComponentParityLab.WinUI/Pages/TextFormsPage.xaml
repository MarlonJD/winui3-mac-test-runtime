<Page
    x:Class="ComponentParityLab.WinUI.TextFormsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel x:Name="TextFormsRoot" Padding="24,20,24,24" Spacing="10">
        <TextBlock x:Name="TextFormsTitle" Text="Page 2: Text and forms" />
        <TextBlock x:Name="SearchLabel" Text="Search label" AutomationProperties.Name="Search label" />
        <TextBox x:Name="SearchTextBox" Text="Public query" AutomationProperties.Name="Search public records" />
        <Button x:Name="ApplyTextButton" Content="Apply text" Click="OnApplyTextClicked" />
        <TextBlock x:Name="TextFormsStateText" Text="Text form is ready" />
        <StackPanel Orientation="Horizontal" Spacing="14">
            <ContentControl x:Name="DiagnosticRichTextBlock" />
            <ContentControl x:Name="DiagnosticRichEditBox" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="14">
            <ContentControl x:Name="DiagnosticPasswordBox" />
            <ContentControl x:Name="DiagnosticNumberBox" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="14">
            <ContentControl x:Name="DiagnosticAutoSuggestBox" />
            <ContentControl x:Name="DiagnosticAutoSuggestBoxQueryIcon" />
        </StackPanel>
        <ContentControl x:Name="DiagnosticFormsPattern" />
    </StackPanel>
</Page>
