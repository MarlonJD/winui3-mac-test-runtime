<Page
    x:Class="ComponentParityLab.WinUI.LayoutMediaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="LabAccentBrush" Color="#2562D9" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="LabAccentBrush" Color="#7CA7FF" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="LabAccentBrush" Color="#FFFF00" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <Color x:Key="LabAccentColor">#2562D9</Color>
            <SolidColorBrush x:Key="LabAccentBrush" Color="#2562D9" />
            <CornerRadius x:Key="LabCornerRadius">8</CornerRadius>
            <x:String x:Key="LabStaticText">Static resource resolved</x:String>
            <Style x:Key="LabTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource LabAccentBrush}" />
            </Style>
        </ResourceDictionary>
    </Page.Resources>
    <ScrollViewer x:Name="LayoutScrollViewer" VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="LayoutMediaRoot" Padding="24,20,24,24" Spacing="10">
            <TextBlock x:Name="LayoutMediaTitle" Text="Page 8: Layout, media, visuals" Style="{StaticResource LabTextStyle}" />
            <Grid x:Name="LayoutResourceGrid" ColumnDefinitions="160,*" ColumnSpacing="16">
                <Border x:Name="LayoutBorder" CornerRadius="{StaticResource LabCornerRadius}">
                    <StackPanel x:Name="LayoutNestedStack" Spacing="6">
                        <TextBlock x:Name="StaticResourceText" Text="{StaticResource LabStaticText}" />
                        <TextBlock x:Name="ThemeResourceText" Text="ThemeResource row" Foreground="{ThemeResource LabAccentBrush}" />
                        <FontIcon x:Name="LayoutFontIcon" Glyph="&#xE8A7;" FontSize="18" />
                    </StackPanel>
                </Border>
                <Image x:Name="PublicImagePlaceholder" Grid.Column="1" Source="public-placeholder.png" />
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="14">
                <ContentControl x:Name="DiagnosticSymbolIcon" />
                <ContentControl x:Name="DiagnosticXamlControlsResources" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="14">
                <ContentControl x:Name="DiagnosticThemeDictionaries" />
                <ContentControl x:Name="DiagnosticColor" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="14">
                <ContentControl x:Name="DiagnosticSolidColorBrush" />
                <ContentControl x:Name="DiagnosticCornerRadius" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="14">
                <ContentControl x:Name="DiagnosticExpander" />
                <ContentControl x:Name="DiagnosticAnnotatedScrollbar" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="14">
                <ContentControl x:Name="DiagnosticSemanticZoom" />
                <ContentControl x:Name="DiagnosticSplitView" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="14">
                <ContentControl x:Name="DiagnosticTwoPaneView" />
                <ContentControl x:Name="DiagnosticAnimatedIcon" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="14">
                <ContentControl x:Name="DiagnosticShapes" />
                <ContentControl x:Name="DiagnosticMediaPlayerElement" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="14">
                <ContentControl x:Name="DiagnosticWebView2" />
                <ContentControl x:Name="DiagnosticInkControls" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="14">
                <ContentControl x:Name="DiagnosticTitleBarCustomization" />
                <ContentControl x:Name="DiagnosticSystemBackdrop" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
