<Window
    x:Class="ProductionSmoke.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Production Smoke Workbench">
    <Window.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="SmokeAccentBrush" Color="#2562D9" />
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="SmokeAccentBrush" Color="#2562D9" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="SmokeAccentBrush" Color="#7CA7FF" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="SmokeAccentBrush" Color="#FFFF00" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <NavigationView
        x:Name="RootNavigation"
        CompactPaneLength="56"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        OpenPaneLength="236"
        PaneDisplayMode="Left"
        SelectionChanged="OnNavigationSelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="DashboardNavigationItem" Content="Dashboard" Tag="dashboard">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE80F;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="OperationsNavigationItem" Content="Operations" Tag="operations">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE8A5;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="SettingsNavigationItem" Content="Settings" Tag="settings">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE713;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>
        <NavigationView.PaneFooter>
            <StackPanel Padding="12,8,12,12" Spacing="8">
                <InfoBar
                    x:Name="FooterStatus"
                    IsOpen="True"
                    Message="Public fixture only"
                    Severity="Informational"
                    Title="Safe data" />
                <Button
                    x:Name="RefreshButton"
                    Click="OnRefreshClicked"
                    Content="Refresh" />
            </StackPanel>
        </NavigationView.PaneFooter>
        <Frame x:Name="SmokeFrame">
            <Frame.Content>
                <ScrollViewer x:Name="SmokeScrollViewer" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="SmokeRoot" Padding="24,20,24,24" Spacing="12">
                        <TextBlock x:Name="SmokeTitleText" Text="Production smoke workbench" Foreground="{ThemeResource SmokeAccentBrush}" />
                        <Grid x:Name="SmokeGrid" ColumnDefinitions="300,*" ColumnSpacing="24">
                            <StackPanel x:Name="FormPanel" Spacing="8">
                                <TextBlock Text="Review form" />
                                <TextBox
                                    x:Name="OwnerTextBox"
                                    AutomationProperties.Name="Owner"
                                    Text="Public owner" />
                                <TextBox
                                    x:Name="SummaryTextBox"
                                    AutomationProperties.Name="Summary"
                                    Text="Public production smoke request" />
                                <ComboBox x:Name="PriorityComboBox" PlaceholderText="Priority" SelectedIndex="1">
                                    <ComboBox.Items>
                                        <TextBlock Text="Low" />
                                        <TextBlock Text="Normal" />
                                        <TextBlock Text="High" />
                                    </ComboBox.Items>
                                </ComboBox>
                                <Button
                                    x:Name="SaveFormButton"
                                    Click="OnSaveFormClicked"
                                    Content="Save form" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="10">
                                <CommandBar x:Name="SmokeCommandBar">
                                    <CommandBar.PrimaryCommands>
                                        <AppBarButton x:Name="ApproveCommand" Label="Approve" Click="OnApproveClicked">
                                            <AppBarButton.Icon>
                                                <FontIcon Glyph="&#xE73E;" />
                                            </AppBarButton.Icon>
                                        </AppBarButton>
                                        <AppBarButton x:Name="DeferCommand" Label="Defer" Click="OnDeferClicked">
                                            <AppBarButton.Icon>
                                                <FontIcon Glyph="&#xE823;" />
                                            </AppBarButton.Icon>
                                        </AppBarButton>
                                    </CommandBar.PrimaryCommands>
                                </CommandBar>
                                <InfoBar
                                    x:Name="SmokeStatus"
                                    IsOpen="True"
                                    Message="Ready for deterministic public smoke run."
                                    Severity="Informational"
                                    Title="Ready" />
                                <ListView x:Name="OperationsList" SelectedIndex="0">
                                    <ListView.Items>
                                        <TextBlock Text="Validate public request" />
                                        <TextBlock Text="Review generated artifact" />
                                        <TextBlock Text="Publish sanitized result" />
                                    </ListView.Items>
                                </ListView>
                                <Border x:Name="DecisionPanel" CornerRadius="8">
                                    <StackPanel Spacing="6">
                                        <TextBlock x:Name="DetailTitleText" Text="Selected operation" />
                                        <TextBlock x:Name="DetailStateText" Text="State: Ready" />
                                        <Button
                                            x:Name="DecisionDialogButton"
                                            Click="OnDecisionClicked"
                                            Content="Decision dialog" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Frame.Content>
        </Frame>
    </NavigationView>
</Window>
